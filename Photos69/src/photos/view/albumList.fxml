<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="photos.controller.AlbumListController"
      spacing="12"
      prefWidth="650"
      prefHeight="500"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="My Albums"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Album table — binds to AlbumListController columns -->
    <TableView fx:id="albumTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn"      text="Album Name" prefWidth="220"/>
            <TableColumn fx:id="countColumn"     text="Photos"     prefWidth="80"/>
            <TableColumn fx:id="dateRangeColumn" text="Date Range" prefWidth="280"/>
        </columns>
    </TableView>

    <!-- Album CRUD buttons -->
    <HBox spacing="10">
        <Button text="Open"          onAction="#handleOpenAlbum"   prefWidth="100"
                style="-fx-background-color: #0096c7; -fx-text-fill: white;"/>
        <Button text="Create Album"  onAction="#handleCreateAlbum" prefWidth="120"/>
        <Button text="Delete Album"  onAction="#handleDeleteAlbum" prefWidth="120"
                style="-fx-background-color: #e63946; -fx-text-fill: white;"/>
        <Button text="Rename Album"  onAction="#handleRenameAlbum" prefWidth="120"/>
    </HBox>

    <!-- Bottom bar: search and logout -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Search Photos" onAction="#handleSearch"  prefWidth="130"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Logout"        onAction="#handleLogout"  prefWidth="100"/>
    </HBox>

</VBox>
